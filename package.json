{
  "name": "@arieltoledo/codehive",
  "version": "0.1.0",
  "description": "Multi-Agent Orchestration Platform — coordinate, observe, and audit swarms of AI coding agents via a shared MCP server",
  "type": "module",
  "bin": {
    "hive": "cli/bin.mjs"
  },
  "files": [
    "cli/",
    "mcp/",
    "server/",
    "prisma/schema.prisma",
    "README.md"
  ],
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "prisma db push && tsx server/index.ts",
    "test": "prisma generate && vitest run --passWithNoTests"
  },
  "engines": {
    "node": ">=21.0.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.2.0",
    "@modelcontextprotocol/sdk": "^1.13.0",
    "@prisma/client": "^6.10.0",
    "fastify": "^5.3.0",
    "prisma": "^6.10.0",
    "strip-json-comments": "^5.0.3",
    "tsx": "^4.19.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anomalyco/codehive.git"
  },
  "keywords": [
    "mcp",
    "ai-agents",
    "orchestration",
    "swarm",
    "coordination",
    "code-agents"
  ],
  "license": "MIT",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "author": "Luis Ariel Toledo",
  "bugs": {
    "url": "https://github.com/anomalyco/codehive/issues"
  },
  "homepage": "https://github.com/anomalyco/codehive#readme"
}
